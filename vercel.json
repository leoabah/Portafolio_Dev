{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/Portafolio_Dev",
      "destination": "/"
    },
    {
      "source": "/Portafolio_Dev/:path*",
      "destination": "/:path*"
    }
  ]
}
